{
  "rewrites": [
    { "source": "/bonus",             "destination": "/v2-bonus-dashboard" },
    { "source": "/goals-summary",     "destination": "/v2-goals-summary" },
    { "source": "/goals-departments", "destination": "/v2-goals-departments" },
    { "source": "/bonus-rings",       "destination": "/v3-bonus-rings" }
  ],
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",   "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",   "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
